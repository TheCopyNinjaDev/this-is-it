TELEGRAM_BOT_TOKEN=1234567890:telegram-bot-token
TELEGRAM_BOT_USERNAME=thisis_it_bot
BROADCAST_CODEWORD=my-secret-broadcast-word
# Optional but recommended for direct Mini App opening from invite links.
# Set this to the exact BotFather Mini App short name, usually lowercase, e.g. app
TELEGRAM_MINI_APP_SHORT_NAME=thisisit

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=this-is-it

JWT_SECRET_KEY=replace-with-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

FRONTEND_BASE_URL=http://localhost:5173
VITE_API_BASE_URL=/api

# OpenRouter is required for the paid/free "create your own date" flow.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# Optional model override for custom date generation.
OPENROUTER_MODEL=qwen/qwen3-30b-a3b
# Optional:
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

S3_KEY=your-yandex-object-storage-key
S3_SECRET_KEY=your-yandex-object-storage-secret
S3_BUCKET_NAME=your-bucket-name
# Optional:
# S3_ENDPOINT_URL=https://storage.yandexcloud.net
# S3_REGION=ru-central1

# Price for custom date generation is configured in admin, not via .env.

# Optional override for Docker when Postgres is running on the host machine.
# On macOS/Windows the default in docker-compose is already host.docker.internal.
# POSTGRES_HOST_DOCKER=host.docker.internal
